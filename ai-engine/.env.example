# AI 连接配置 — 复制为 .env 后按实际后端填写
# 支持任何 OpenAI 兼容 API（Ollama、OpenAI、DeepSeek、硅基流动等）

# API 根地址（须含 /v1，脚本会请求 /chat/completions）
AI_BASE_URL=http://127.0.0.1:11434/v1

# 鉴权密钥；本地 Ollama 等无鉴权场景可留空
AI_API_KEY=

# 默认模型
AI_MODEL=deepseek-r1:14b

# 生成参数 — 详见 params.md
AI_TEMPERATURE=0.6
AI_MAX_TOKENS=8192
AI_TOP_P=0.9

# 可选：系统提示文件路径（相对仓库根目录）
# AI_SYSTEM_PROMPT_FILE=skills/pro-generation.md
